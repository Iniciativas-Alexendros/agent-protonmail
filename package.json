{
  "name": "@alexendros/protonmail-mcp",
  "version": "0.4.0",
  "mcpName": "io.github.Alexendros/protonmail-mcp",
  "description": "MCP server for Proton Mail via Proton Mail Bridge (IMAP/SMTP). Dual transport: stdio + streamable HTTP.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "protonmail-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iniciativas-Alexendros/protonmailbrige-mcptool.git"
  },
  "homepage": "https://github.com/Iniciativas-Alexendros/protonmailbrige-mcptool#readme",
  "bugs": {
    "url": "https://github.com/Iniciativas-Alexendros/protonmailbrige-mcptool/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proton-mail",
    "proton-bridge",
    "imap",
    "smtp",
    "email",
    "ai-agent",
    "agent-tool"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:local": "bash scripts/e2e-greenmail.sh",
    "smoke": "bash scripts/smoke.sh",
    "license-check": "license-checker --direct --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;MIT-0;MPL-2.0;CC-BY-3.0;CC0-1.0;(MIT OR EUPL-1.1+)'",
    "license-check:prod": "license-checker --direct --production --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;MIT-0;(MIT OR EUPL-1.1+)'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "imapflow": "^1.4.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "license-checker": "^25.0.1",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
